{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PA Stop EXE",
      "type": "shell",
      "command": "$process = Get-Process personal_assistant -ErrorAction SilentlyContinue; if ($process) { $process | Stop-Process -Force }; exit 0",
      "problemMatcher": []
    },
    {
      "label": "PA Build Windows",
      "type": "shell",
      "command": "flutter build windows",
      "options": {
        "cwd": "${workspaceFolder}/app"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "PA Run Release EXE",
      "type": "shell",
      "command": "Start-Process -FilePath \"${workspaceFolder}\\app\\build\\windows\\x64\\runner\\Release\\personal_assistant.exe\"",
      "problemMatcher": []
    },
    {
      "label": "PA Smart Build + Run EXE",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\.vscode\\run_release_smart.ps1\"",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "PA Build + Run EXE",
      "dependsOrder": "sequence",
      "dependsOn": [
        "PA Stop EXE",
        "PA Build Windows",
        "PA Run Release EXE"
      ],
      "problemMatcher": []
    },
    {
      "label": "PA Make Release",
      "type": "shell",
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\make_release.ps1\"",
      "problemMatcher": []
    }
  ]
}
